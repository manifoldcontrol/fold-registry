symbol open_blowup_regularisation:
  id: csr.Fold.open_blowup_regularisation
  namespace: Fold
  framework_layer: domain
  owning_document: csr.document.Fold_Paper
  display_name: "OPEN: full-divisor blow-up regularisation of the 1/x singularity"
  type: open_problem
  status: candidate
  definition_home: csr.document.Fold_Paper@v74#section.8.2.open_blowup
  definition: "v74: OPEN, narrowed. Full chart atlas and transition maps derived and computer-algebra verified (par. 6.1); inner chart solved in closed form (par. 6); K1 entry, K2 passage (uniform transient bounds, alpha-correction) and K3 exit landing (un-blowing to the classical slow manifold) PROVED by invariant-manifold arguments, all computations machine-checked (Lemmas 2-4, par. 6.2). Remaining: the gluing of the legs, where the uniform Gronwall-level estimates live, and time asymptotics. Prerequisite for the uniform-in-delta result."
  definition_hash: auto
  source_anchor:
    document: csr.document.Fold_Paper
    version: v74
    section: "8.2"
    anchor: open_blowup
