symbol open_uniform_delta:
  id: csr.Fold.open_uniform_delta
  namespace: Fold
  framework_layer: domain
  owning_document: csr.document.Fold_Paper
  display_name: "OPEN: uniform-in-delta certification at fixed eps"
  type: open_problem
  status: candidate
  definition_home: csr.document.Fold_Paper@v74#section.8.2.open_uniform_delta
  definition: "Uniform-in-delta certification at fixed epsilon (joint limit delta->0) remains OPEN; epsilon_0(delta,r) -> 0 as delta -> 0, so blow-up resolution is required. v74: mechanism identified in the inner chart (par. 6); all three chart legs now PROVEN (Lemmas 2-4, par. 6.2); the gluing is still open, and with it this claim."
  definition_hash: auto
  source_anchor:
