symbol open_blowup_regularisation:
  id: csr.Fold.open_blowup_regularisation
  namespace: Fold
  framework_layer: domain
  owning_document: csr.document.Fold_Paper
  display_name: "OPEN: full-divisor blow-up regularisation of the 1/x singularity"
  type: open_problem
  status: candidate
  definition_home: csr.document.Fold_Paper@v69#section.8.2.open_blowup
  definition: "v69: full chart atlas and transition maps derived and computer-algebra verified (par. 6.1); inner chart solved in closed form (par. 6); matching, alpha-correction, and time bookkeeping sketched (par. 6.2-6.3), not rigorous. Still open: centre-manifold existence through the blow-up, uniform transient bounds, time asymptotics. Prerequisite for the uniform-in-delta result."
  definition_hash: auto
  source_anchor:
